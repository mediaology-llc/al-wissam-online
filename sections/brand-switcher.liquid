{%- comment -%}
  Global brand switcher displayed above the header. Allows visitors to jump
  between sister stores (AL WISSAM, Retail Store, Lil Woo). Designed to sit
  cleanly above the existing Prestige header group without altering its
  built-in sticky behaviour.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
  <style>
    {%- comment -%}
      Publish sticky-related variables on :root so siblings (header,
      announcement-bar) can inherit them — CSS variables only flow down
      the ancestor chain, not across siblings. --brand-switcher-height
      is set in JS below; the fallback here keeps things sane during
      first paint before the script runs.
    {%- endcomment -%}
    :root {
      --brand-switcher-is-sticky: {% if section.settings.enable_sticky %}1{% else %}0{% endif %};
      --brand-switcher-height: 36px;
    }

    #shopify-section-{{ section.id }} {
      --brand-switcher-bg: {{ section.settings.background_color }};
      --brand-switcher-fg: {{ section.settings.text_color }};
      --brand-switcher-accent: {{ section.settings.active_color }};
      --brand-switcher-divider: {{ section.settings.text_color }};

      position: relative;
      z-index: 6;
    }

    {%- if section.settings.enable_sticky -%}
      #shopify-section-{{ section.id }} {
        position: sticky;
        top: 0;
      }

      {%- comment -%}
        Push the announcement bar and header below us when we are sticky.
        Scoped to siblings of our section so the original Prestige rules
        keep working when this section is removed.
      {%- endcomment -%}
      .shopify-section--brand-switcher ~ .shopify-section--announcement-bar {
        top: calc(var(--brand-switcher-height, 36px)) !important;
      }

      .shopify-section--brand-switcher ~ .shopify-section--header {
        top: calc(
          var(--brand-switcher-height, 36px)
          + var(--announcement-bar-is-sticky, 0) * var(--announcement-bar-height, 0px)
        ) !important;
      }
    {%- endif -%}

    .brand-switcher {
      background: var(--brand-switcher-bg);
      color: var(--brand-switcher-fg);
      padding-block: 0.625rem;
      padding-inline: 1.25rem;
      font-family: var(--heading-font-family, inherit);
      font-size: 0.6875rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 500;
      line-height: 1;
    }

    .brand-switcher__list {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
      margin: 0;
      padding: 0;
      list-style: none;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .brand-switcher__list::-webkit-scrollbar { display: none; }

    .brand-switcher__item {
      display: inline-flex;
      align-items: center;
      white-space: nowrap;
    }

    .brand-switcher__item:not(:last-child)::after {
      content: '';
      display: inline-block;
      width: 1px;
      height: 0.75rem;
      margin-inline-start: 1.25rem;
      background: var(--brand-switcher-divider);
      opacity: 0.35;
    }

    .brand-switcher__link {
      position: relative;
      display: inline-block;
      padding-block: 0.25rem;
      color: inherit;
      letter-spacing: inherit;
      text-decoration: none;
      opacity: 0.65;
      transition: opacity 0.2s ease;
    }

    .brand-switcher__link:hover,
    .brand-switcher__link:focus-visible {
      opacity: 1;
    }

    .brand-switcher__link:focus-visible {
      outline: 1px solid currentColor;
      outline-offset: 3px;
    }

    .brand-switcher__link--active {
      color: var(--brand-switcher-accent);
      opacity: 1;
      font-weight: 600;
    }

    .brand-switcher__link--active::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: -0.25rem;
      height: 1px;
      background: currentColor;
    }

    @media screen and (max-width: 699px) {
      .brand-switcher {
        padding-block: 0.5rem;
        padding-inline: 0.75rem;
        font-size: 0.625rem;
        letter-spacing: 0.16em;
      }
      .brand-switcher__list { gap: 0.75rem; }
      .brand-switcher__item:not(:last-child)::after {
        margin-inline-start: 0.75rem;
        height: 0.6875rem;
      }
    }
  </style>

  <nav class="brand-switcher" aria-label="{{ section.settings.aria_label | default: 'Brand switcher' | escape }}">
    <ul class="brand-switcher__list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign label = block.settings.label
          assign link_url = block.settings.link
          assign is_active = block.settings.is_active

          # Infer which brand each entry maps to by matching its link URL.
          # This lets the router script (al-wissam-brand-router.js) light up
          # the active pill based on the visitor's current brand cookie,
          # rather than the static is_active flag.
          assign brand_target = 'al-wissam'
          assign normalized_link = link_url | downcase
          if normalized_link contains '/lil-woo'
            assign brand_target = 'lil-woo'
          elsif normalized_link contains '/retail'
            assign brand_target = 'retail'
          endif
        -%}

        {%- if label != blank -%}
          <li class="brand-switcher__item" {{ block.shopify_attributes }}>
            {%- if is_active and link_url != blank -%}
              <a href="{{ link_url }}" class="brand-switcher__link brand-switcher__link--active" data-aw-brand-target="{{ brand_target }}" aria-current="page">{{ label }}</a>
            {%- elsif is_active -%}
              <span class="brand-switcher__link brand-switcher__link--active" data-aw-brand-target="{{ brand_target }}" aria-current="page">{{ label }}</span>
            {%- elsif link_url != blank -%}
              <a href="{{ link_url }}" class="brand-switcher__link" data-aw-brand-target="{{ brand_target }}">{{ label }}</a>
            {%- else -%}
              <span class="brand-switcher__link" data-aw-brand-target="{{ brand_target }}">{{ label }}</span>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>

  <script>
    (function () {
      var section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section) return;
      var setHeight = function () {
        document.documentElement.style.setProperty(
          '--brand-switcher-height',
          section.clientHeight.toFixed(2) + 'px'
        );
      };
      setHeight();
      if ('ResizeObserver' in window) {
        new ResizeObserver(setHeight).observe(section);
      } else {
        window.addEventListener('resize', setHeight);
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Brand switcher",
  "class": "shopify-section--brand-switcher",
  "limit": 1,
  "enabled_on": {
    "groups": ["header"]
  },
  "tag": "aside",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "brand",
      "name": "Brand link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "AL WISSAM"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Mark as active (current store)",
          "info": "Highlights this entry and renders it as plain text instead of a link.",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Stick to top of page on scroll",
      "default": true
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Brand switcher"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active text",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Brand switcher",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "label": "AL WISSAM",
            "is_active": true
          }
        },
        {
          "type": "brand",
          "settings": {
            "label": "RETAIL STORE"
          }
        },
        {
          "type": "brand",
          "settings": {
            "label": "LIL WOO"
          }
        }
      ]
    }
  ]
}
{% endschema %}
